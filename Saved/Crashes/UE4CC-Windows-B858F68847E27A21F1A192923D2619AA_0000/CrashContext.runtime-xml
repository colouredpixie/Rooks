		<SourceContext>  525       		// Attempting to track down UE-45505, where it looks as if somehow a skeletal mesh component&apos;s mesh has only been partially loaded, causing a mismatch in the LOD arrays
  526       		checkf(!SkeletalMesh-&gt;HasAnyFlags(RF_NeedLoad | RF_NeedPostLoad | RF_NeedPostLoadSubobjects | RF_WillBeLoaded), TEXT(&quot;Attempting to create render state for a skeletal mesh that is is not fully loaded. Mesh: %s&quot;), *SkeletalMesh-&gt;GetName());
  527       
  528       		// Initialize the alternate weight tracks if present BEFORE creating the new mesh object
  529       		InitLODInfos();
  530       
  531       		// No need to create the mesh object if we aren&apos;t actually rendering anything (see UPrimitiveComponent::Attach)
  532       		if ( FApp::CanEverRender() &amp;&amp; ShouldComponentAddToScene() )
  533       		{
  534       			ERHIFeatureLevel::Type SceneFeatureLevel = GetWorld()-&gt;FeatureLevel;
  535       			FSkeletalMeshRenderData* SkelMeshRenderData = SkeletalMesh-&gt;GetResourceForRendering();
  536       			int32 MinLODIndex = ComputeMinLOD();
  537       			
  538       #if DO_CHECK
  539 ***** 			for (int LODIndex = MinLODIndex; LODIndex &lt; SkelMeshRenderData-&gt;LODRenderData.Num(); LODIndex++)
  540       			{
  541       				FSkeletalMeshLODRenderData&amp; LODData = SkelMeshRenderData-&gt;LODRenderData[LODIndex];
  542       				const FPositionVertexBuffer* PositionVertexBufferPtr = &amp;LODData.StaticVertexBuffers.PositionVertexBuffer;
  543       				if (!PositionVertexBufferPtr || (PositionVertexBufferPtr-&gt;GetNumVertices() &lt;= 0))
  544       				{
  545       					UE_LOG(LogSkinnedMeshComp, Warning, TEXT(&quot;Invalid Lod %i for Rendering Asset: %s&quot;), LODIndex, *SkeletalMesh-&gt;GetFullName());
  546       				}
  547       			}
  548       #endif
  549       	
  550       			// Also check if skeletal mesh has too many bones/chunk for GPU skinning.
  551       			if (bRenderStatic)
  552       			{
  553       				// GPU skin vertex buffer + LocalVertexFactory
  554       				MeshObject = ::new FSkeletalMeshObjectStatic(this, SkelMeshRenderData, SceneFeatureLevel); </SourceContext>
